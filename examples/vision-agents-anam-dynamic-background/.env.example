# Stream (https://getstream.io/try-for-free/)
STREAM_API_KEY=
STREAM_API_SECRET=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Deepgram (used for STT + TTS)
DEEPGRAM_API_KEY=

# Anam
ANAM_API_KEY=
ANAM_AVATAR_ID=
ANAM_AVATAR_WIDTH=1280
ANAM_AVATAR_HEIGHT=720
# Optional chroma-key tuning (useful if you see green spill/banding on edges)
ANAM_GREEN_THRESHOLD=60
ANAM_GREEN_BIAS=.9
ANAM_GREEN_TOLERANCE=50
ANAM_GREEN_EDGE_EXPAND=20
